{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^u--(.*)": "uview-plus/components/u-$1/u-$1.vue",
			"^up-(.*)": "uview-plus/components/u-$1/u-$1.vue",
			"^u-([^-].*)": "uview-plus/components/u-$1/u-$1.vue",
			"^nut-(.*)?-(.*)": "nutui-uniapp/components/$1$2/$1$2.vue",
			"^nut-(.*)": "nutui-uniapp/components/$1/$1.vue",
			"^comp-(.*)": "@/components/$1/index.vue",
			"^comp-(.*)?-(.*)": "@/components/$1$2/index.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/webview/index"
		},
		{
			"path": "pages/jump/jump",
			"style": {
				"navigationBarTitleText": "跳板页",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/login/index",
			"style": {
				"navigationBarTitleText": "",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/order/order",
			"style": {
				"navigationBarTitleText": "",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/my/my",
			"style": {
				"navigationBarTitleText": "个人中心",
				"navigationStyle": "custom"
			}
		}
	],
	"subPackages": [],
	"tabBar": {
		"color": "#333333",
		"selectedColor": "#F00000",
		"borderStyle": "black",
		"backgroundColor": "#ffffff",
		"height": "50px",
		"fontSize": "10px",
		"iconWidth": "20px",
		"list": [
			{
				"pagePath": "pages/index/index",
				"iconPath": "static/newImage/icon/homeIcoTab.png",
				"selectedIconPath": "static/newImage/icon/activeHomeIcoTab.png",
				"text": "首页"
			},
			{
				"pagePath": "pages/order/order",
				"iconPath": "static/newImage/icon/orderIcoTab.png",
				"selectedIconPath": "static/newImage/icon/activeOrderIcoTab.png",
				"text": "订单"
			},
			{
				"pagePath": "pages/my/my",
				"iconPath": "static/newImage/icon/myIcoTab.png",
				"selectedIconPath": "static/newImage/icon/activeMyIcoTab.png",
				"text": "我的"
			}
		]
	},
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "惠民口福",
		"navigationBarBackgroundColor": "#f7f7f7",
		"backgroundColor": "#f7f7f7"
	},
	"uniIdRouter": {
		"loginPage": "pages/login/index",
		"needLogin": []
	}
}
